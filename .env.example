# Copy to .env and adjust. docker-compose reads it automatically.

# Random string; rotate for production.
SESSION_SECRET=change-me-to-a-long-random-string

# Set true only when serving over HTTPS (marks the session cookie Secure).
COOKIE_SECURE=false

# Optional: comma-separated emails auto-granted admin on signup.
# (The very first registered account always becomes admin regardless.)
ADMIN_EMAILS=

# The abstract territory extent (unit-less map units) and grid spacing.
TERRITORY_NAME=Libertaria
TERRITORY_MIN_X=-1000
TERRITORY_MIN_Y=-1000
TERRITORY_MAX_X=1000
TERRITORY_MAX_Y=1000
TERRITORY_GRID=100
